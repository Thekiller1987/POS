rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función auxiliar para determinar si el usuario es un administrador
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Reglas para la colección de usuarios
    match /users/{userId} {
      // Cualquier usuario autenticado puede leer los perfiles.
      // Un usuario puede escribir su propio perfil (necesario para el registro inicial y autocuración).
      // Un administrador también puede escribir cualquier perfil de usuario.
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == userId || isAdmin()
      );
    }
    
    // Reglas para la colección de productos
    match /products/{productId} {
      // Cualquier usuario autenticado puede ver productos.
      // Solo los administradores pueden crear, modificar o eliminar productos.
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Reglas para la colección de ventas
    match /sales/{saleId} {
      // Cualquier usuario autenticado puede ver y registrar ventas.
      allow read, write: if request.auth != null;
    }
    
    // Reglas para la colección de categorías
    match /categories/{categoryId} {
      // Cualquier usuario autenticado puede ver categorías.
      // Solo los administradores pueden crear, modificar o eliminar categorías.
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
